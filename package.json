{
  "name": "hacker-news-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsoa spec && tsoa routes && tsx src/index.ts",
    "build": "tsoa spec && tsoa routes && tsc && npm run copy-views",
    "copy-views": "node -e \"const {cpSync}=require('fs');cpSync('src/views','dist/views',{recursive:true})\"",
    "start": "node dist/index.js",
    "tsoa:gen": "tsoa spec && tsoa routes"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "axios": "^1.18.1",
    "axios-cookiejar-support": "^7.0.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "dotenv": "^17.4.2",
    "express": "5",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "~1.9.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pug": "^3.0.4",
    "rate-limit-redis": "^5.0.0",
    "swagger-ui-express": "^5.0.1",
    "tough-cookie": "^6.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/swagger-ui-express": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
